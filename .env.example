# =============================================================================
# Black Stars — Environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# Validation/typing lives in `src/env.ts` (zod + @t3-oss/env-nextjs).
# Cost context for each service: see SERVICES_AND_COSTS.md.
# Keys are optional until the phase that needs them (noted below) lands.
# =============================================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database — Neon Postgres            (Phase 3 · SERVICES_AND_COSTS.md §1)
# -----------------------------------------------------------------------------
# Pooled connection string from the Neon dashboard (or Vercel/Neon integration).
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/black_stars?sslmode=require

# -----------------------------------------------------------------------------
# Auth — Neon Auth (Stack Auth)       (Phase 4 · SERVICES_AND_COSTS.md §1)
# -----------------------------------------------------------------------------
# From Neon Console → Auth, or the Stack Auth dashboard.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# -----------------------------------------------------------------------------
# Email — Resend                      (Phase 16 · SERVICES_AND_COSTS.md §3)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Black Stars <noreply@blackstars.co.ke>

# -----------------------------------------------------------------------------
# Notifications — Twilio (SMS/WhatsApp) (Phase 16 · SERVICES_AND_COSTS.md §2)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+254700000000
# WhatsApp sender, e.g. whatsapp:+14155238886 (Twilio sandbox) or your number
TWILIO_WHATSAPP_FROM=

# -----------------------------------------------------------------------------
# AI — Claude / Anthropic             (Phase 18 · SERVICES_AND_COSTS.md §4)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Default model for routine insights (cheap). Override per-task in code.
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Payments — M-Pesa Daraja            (Phase 17 · SERVICES_AND_COSTS.md §5)
# -----------------------------------------------------------------------------
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=247247
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:3000/api/mpesa/callback
